# VERCEL PRODUCTION ENVIRONMENT VARIABLES
# Copy these to Vercel Dashboard > Settings > Environment Variables
# Replace values with your actual production credentials

# App Config
APP_NAME=RPLMantap
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_URL=https://your-vercel-domain.vercel.app
APP_TIMEZONE=Asia/Jakarta

# Localization
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Logging (stderr for Vercel serverless)
LOG_CHANNEL=stderr
LOG_LEVEL=info

# Database - PlanetScale MySQL (Recommended for Vercel)
DB_CONNECTION=mysql
DB_HOST=aws.connect.psdb.cloud
DB_PORT=3306
DB_DATABASE=rplmantap
DB_USERNAME=YOUR_PLANETSCALE_USERNAME
DB_PASSWORD=YOUR_PLANETSCALE_PASSWORD

# Alternative: Supabase PostgreSQL
# DB_CONNECTION=pgsql
# DB_HOST=xxxxx.supabase.co
# DB_PORT=5432
# DB_DATABASE=postgres
# DB_USERNAME=postgres
# DB_PASSWORD=YOUR_SUPABASE_PASSWORD

# Session (cookie for serverless)
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcast
BROADCAST_CONNECTION=log

# Filesystem (local or S3 for production)
FILESYSTEM_DISK=local

# Queue (sync for serverless, no background workers needed)
QUEUE_CONNECTION=sync

# Cache (array for stateless serverless)
CACHE_STORE=array

# Mail
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@rplmantap.app"
MAIL_FROM_NAME="RPL Mantap"

# AWS S3 (optional, for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite
VITE_APP_NAME="${APP_NAME}"
